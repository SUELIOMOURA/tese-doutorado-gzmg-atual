x = "Saúde percebida",
y = "log(visits + 0.5)"
)
# Boxplot por sexo
ggplot(nmes, aes(x = gender, y = log(visits + 0.5))) +
geom_boxplot() +
labs(
title = "log(visits + 0.5) por sexo",
x = "Sexo",
y = "log(visits + 0.5)"
)
# Boxplot por seguro privado
ggplot(nmes, aes(x = insurance, y = log(visits + 0.5))) +
geom_boxplot() +
labs(
title = "log(visits + 0.5) por seguro privado",
x = "Seguro privado",
y = "log(visits + 0.5)"
)
# Relação com número de doenças crônicas
ggplot(nmes, aes(x = chronic, y = visits)) +
geom_jitter(height = 0.1, width = 0.1, alpha = 0.3) +
labs(
title = "Visits versus número de condições crônicas",
x = "Número de condições crônicas",
y = "Número de visitas médicas"
)
# Relação com anos de estudo
ggplot(nmes, aes(x = school, y = visits)) +
geom_jitter(height = 0.1, width = 0.1, alpha = 0.3) +
labs(
title = "Visits versus anos de estudo",
x = "Anos de estudo",
y = "Número de visitas médicas"
)
mod_pois <- glm(
visits ~ health + chronic + gender + school + insurance,
data = nmes,
family = poisson(link = "log")
)
summary(mod_pois)
# Erros-padrão robustos
coeftest(mod_pois, vcov = sandwich)
dispersiontest(mod_pois)
dispersiontest(mod_pois, trafo = 2)
mod_nb <- glm.nb(
visits ~ health + chronic + gender + school + insurance,
data = nmes
)
summary(mod_nb)
# Comparação Poisson vs NB
AIC(mod_pois, mod_nb)
BIC(mod_pois, mod_nb)
lrtest(mod_pois, mod_nb)
# Modelo hurdle binomial negativa
mod_hurdle_nb <- hurdle(
visits ~ health + chronic + gender + school + insurance |
chronic + gender + school + insurance,
data = nmes,
dist = "negbin"
)
summary(mod_hurdle_nb)
# Modelo zero-inflated binomial negativa
mod_zinb <- zeroinfl(
visits ~ health + chronic + gender + school + insurance |
chronic + gender + school + insurance,
data = nmes,
dist = "negbin"
)
summary(mod_zinb)
AIC(mod_pois, mod_nb, mod_hurdle_nb, mod_zinb)
BIC(mod_pois, mod_nb, mod_hurdle_nb, mod_zinb)
# Comparação não aninhada entre hurdle e ZINB
vuong(mod_hurdle_nb, mod_zinb)
# Função auxiliar para proporção esperada de zeros
prop_zero_poisson <- mean(dpois(0, lambda = fitted(mod_pois)))
prop_zero_poisson
# Para NB:
# probabilidade de zero para cada observação usando parâmetros ajustados
mu_nb <- fitted(mod_nb)
theta_nb <- mod_nb$theta
prop_zero_nb <- mean((theta_nb / (theta_nb + mu_nb))^theta_nb)
prop_zero_obs <- mean(nmes$visits == 0)
cat("Proporção observada de zeros:", prop_zero_obs, "\n")
cat("Proporção esperada de zeros - Poisson:", prop_zero_poisson, "\n")
cat("Proporção esperada de zeros - NB:", prop_zero_nb, "\n")
comparacao_modelos <- data.frame(
Modelo = c("Poisson", "Binomial Negativa", "Hurdle NB", "ZINB"),
AIC = c(AIC(mod_pois), AIC(mod_nb), AIC(mod_hurdle_nb), AIC(mod_zinb)),
BIC = c(BIC(mod_pois), BIC(mod_nb), BIC(mod_hurdle_nb), BIC(mod_zinb)),
LogLik = c(logLik(mod_pois), logLik(mod_nb), logLik(mod_hurdle_nb), logLik(mod_zinb))
)
print(comparacao_modelos)
write.csv(resumo_y, "resumo_variavel_visits_NMES1988.csv", row.names = FALSE)
write.csv(comparacao_modelos, "comparacao_modelos_NMES1988.csv", row.names = FALSE)
library(AER)
library(AER)
data("NMES1988", package = "AER")
## =========================================================
## 2) Preparação dos dados
## =========================================================
# Variável de interesse
visits_raw <- NMES1988$visits
# Remover NA, se houver
visits_raw <- na.omit(visits_raw)
make_totals_from_units <- function(x, n_units = 100, shuffle = FALSE, seed = 123) {
x <- as.numeric(x)
x <- x[is.finite(x)]
if (shuffle) {
set.seed(seed)
x <- sample(x, length(x), replace = FALSE)
}
# número de grupos completos
n_groups <- floor(length(x) / n_units)
if (n_groups < 2) {
stop("Número insuficiente de grupos. Reduza 'n_units'.")
}
# manter apenas observações que formam grupos completos
x_use <- x[1:(n_groups * n_units)]
# matriz: cada linha = um subgrupo
mat <- matrix(x_use, nrow = n_groups, ncol = n_units, byrow = TRUE)
# total por subgrupo
totals <- rowSums(mat)
list(
totals = totals,
matrix_units = mat,
n_groups = n_groups,
n_units = n_units
)
}
## ---------- util: limites em ESCALA DE TOTAIS ----------
limits_from_unitvar_TOTAL <- function(mu_unit, var_unit, n_units, L = 3) {
CL_tot  <- n_units * mu_unit
SD_tot  <- sqrt(n_units * var_unit)
UCL_tot <- CL_tot + L * SD_tot
LCL_tot <- max(0, CL_tot - L * SD_tot)
list(CL = CL_tot, UCL = UCL_tot, LCL = LCL_tot)
}
## ---------- variâncias unitárias teóricas ----------
var_unit_pois <- function(mu) mu
var_unit_geom <- function(mu) {
# Geométrica parametrizada como número de falhas antes do primeiro sucesso
mu * (1 + mu)
}
var_unit_gzmg <- function(mu, pi) {
# GZMG-u conforme o seu script original
mu + mu^2 * (1 + pi)/(1 - pi)
}
## ---------- ZIP: estima omega por momentos a partir dos TOTAIS (fase 1) ----------
zip_from_totals <- function(tot_phase1, n_units) {
mu_unit_hat   <- mean(tot_phase1) / n_units
var_total_hat <- stats::var(tot_phase1)
var_unit_hat  <- var_total_hat / n_units
num <- var_unit_hat - mu_unit_hat
den <- mu_unit_hat^2 + var_unit_hat - mu_unit_hat
omega_hat <- if (is.na(den) || den <= 0) 0 else max(0, min(num / den, 0.999))
var_unit_zip <- mu_unit_hat + (omega_hat / (1 - omega_hat)) * mu_unit_hat^2
list(
mu_unit = mu_unit_hat,
var_unit = var_unit_zip,
omega_hat = omega_hat
)
}
## ---------- COM-Poisson: aproximação de momentos a partir dos TOTAIS ----------
cmp_from_totals <- function(tot_phase1, n_units) {
mu_unit_hat   <- mean(tot_phase1) / n_units
var_total_hat <- stats::var(tot_phase1)
var_unit_hat  <- max(1e-8, var_total_hat / n_units)
list(
mu_unit = mu_unit_hat,
var_unit = var_unit_hat
)
}
## ---------- plot genérico (ESCALA DE TOTAIS) ----------
plot_total_chart <- function(tot_all, m, limits, main = "Chart", col_sig = "green",
ylim_common = NULL) {
T <- length(tot_all)
UCLv <- rep(limits$UCL, T)
CLv  <- rep(limits$CL,  T)
LCLv <- rep(limits$LCL, T)
if (is.null(ylim_common)) {
ylim_use <- c(min(LCLv, tot_all), max(UCLv, tot_all))
} else {
ylim_use <- ylim_common
}
plot(UCLv, type = "l", lwd = 3, col = "red",
ylim = ylim_use,
main = main, xlab = "Sample", ylab = "Total Number of Visits")
lines(CLv,  lwd = 2, col = "blue")
lines(LCLv, lwd = 3, col = "red")
lines(seq_len(T), tot_all, lwd = 1.5)
pts_col <- ifelse(tot_all > UCLv | tot_all < LCLv, col_sig, "black")
points(seq_len(T), tot_all, pch = 19, col = pts_col)
abline(v = m + 0.5, col = "blue", lty = 2, lwd = 2)
which(tot_all > UCLv | tot_all < LCLv)
}
## =========================================================
## 4) Função principal adaptada
## =========================================================
plot_realdata_totals_NMES1988 <- function(visits,
n_units = 100,
m = 20,
L = 3,
pi_gzmg = 0.20,
shuffle = FALSE,
seed = 123,
same_ylim = TRUE) {
# transformar variável unitária em totais por subgrupo
grp <- make_totals_from_units(visits, n_units = n_units, shuffle = shuffle, seed = seed)
dados <- grp$totals
if (length(dados) < (m + 1)) {
stop("Número de subgrupos insuficiente. Reduza 'm' ou 'n_units'.")
}
# fase 1 e fase 2
tot1 <- dados[1:m]
tot2 <- dados[(m + 1):length(dados)]
tot  <- c(tot1, tot2)
# estimativa de mu por unidade a partir da Fase 1
mu_unit_hat <- mean(tot1) / n_units
## Limites por modelo (TOTAIS)
lim_gzmg <- limits_from_unitvar_TOTAL(
mu_unit = mu_unit_hat,
var_unit = var_unit_gzmg(mu_unit_hat, pi_gzmg),
n_units = n_units,
L = L
)
zip_est <- zip_from_totals(tot1, n_units)
lim_zip <- limits_from_unitvar_TOTAL(
mu_unit = zip_est$mu_unit,
var_unit = zip_est$var_unit,
n_units = n_units,
L = L
)
lim_pois <- limits_from_unitvar_TOTAL(
mu_unit = mu_unit_hat,
var_unit = var_unit_pois(mu_unit_hat),
n_units = n_units,
L = L
)
lim_geom <- limits_from_unitvar_TOTAL(
mu_unit = mu_unit_hat,
var_unit = var_unit_geom(mu_unit_hat),
n_units = n_units,
L = L
)
cmp_est <- cmp_from_totals(tot1, n_units)
lim_cmp <- limits_from_unitvar_TOTAL(
mu_unit = cmp_est$mu_unit,
var_unit = cmp_est$var_unit,
n_units = n_units,
L = L
)
cat("\n=== Resumo da construção dos subgrupos ===\n")
cat("Número total de observações unitárias:", length(visits), "\n")
cat("Tamanho do subgrupo (n_units):", n_units, "\n")
cat("Número de subgrupos completos:", length(dados), "\n")
cat("Subgrupos na Fase 1 (m):", m, "\n")
cat("Subgrupos na Fase 2:", length(dados) - m, "\n")
cat("\n=== Limites (L =", round(L, 4), ") – escala de TOTAIS ===\n")
print(data.frame(
Modelo = c("GZMG-u", "ZIP", "Poisson", "Geometric", "COM-Poisson"),
LCL    = round(c(lim_gzmg$LCL, lim_zip$LCL, lim_pois$LCL, lim_geom$LCL, lim_cmp$LCL), 2),
CL     = round(c(lim_gzmg$CL,  lim_zip$CL,  lim_pois$CL,  lim_geom$CL,  lim_cmp$CL ), 2),
UCL    = round(c(lim_gzmg$UCL, lim_zip$UCL, lim_pois$UCL, lim_geom$UCL, lim_cmp$UCL), 2)
), row.names = FALSE)
# Definir ylim comum, se desejado
if (same_ylim) {
y_min <- min(
lim_gzmg$LCL, lim_zip$LCL, lim_pois$LCL, lim_geom$LCL, lim_cmp$LCL,
tot
)
y_max <- max(
lim_gzmg$UCL, lim_zip$UCL, lim_pois$UCL, lim_geom$UCL, lim_cmp$UCL,
tot
)
ylim_common <- c(y_min, y_max)
} else {
ylim_common <- NULL
}
## layout: 3 em cima, 2 embaixo
op <- par(mar = c(4.5, 4.8, 3.0, 1.3))
on.exit(par(op), add = TRUE)
layout(matrix(c(1,2,3,4,5,0), nrow = 2, byrow = TRUE))
s_gzmg <- plot_total_chart(tot, m, lim_gzmg, main = "GZMG-u Chart",
ylim_common = ylim_common)
s_zip  <- plot_total_chart(tot, m, lim_zip,  main = "ZIP Chart",
ylim_common = ylim_common)
s_pois <- plot_total_chart(tot, m, lim_pois, main = "Poisson Chart",
ylim_common = ylim_common)
s_geom <- plot_total_chart(tot, m, lim_geom, main = "Geometric Chart",
ylim_common = ylim_common)
s_cmp  <- plot_total_chart(tot, m, lim_cmp,  main = "COM-Poisson Chart",
ylim_common = ylim_common)
invisible(list(
grouped_data = grp,
totals = dados,
phase1 = tot1,
phase2 = tot2,
limits = list(
GZMG = lim_gzmg,
ZIP = lim_zip,
Poisson = lim_pois,
Geometric = lim_geom,
COMPoisson = lim_cmp
),
params = list(
mu_unit_hat = mu_unit_hat,
pi_gzmg = pi_gzmg,
omega_hat = zip_est$omega_hat,
var_unit_cmp = cmp_est$var_unit
),
signals = list(
GZMG = s_gzmg,
ZIP = s_zip,
Poisson = s_pois,
Geometric = s_geom,
COMPoisson = s_cmp
)
))
}
# Exemplo 1: mantendo a ordem original da base
out_L3 <- plot_realdata_totals_NMES1988(
visits = visits_raw,
n_units = 100,
m = 20,
L = 3,
pi_gzmg = 0.20,
shuffle = FALSE,
same_ylim = TRUE
)
cat("\nSinais (L = 3):\n")
print(out_L3$signals)
# Exemplo 2: usando L = qnorm(0.95)
out_L95 <- plot_realdata_totals_NMES1988(
visits = visits_raw,
n_units = 100,
m = 20,
L = qnorm(0.95),
pi_gzmg = 0.20,
shuffle = FALSE,
same_ylim = TRUE
)
cat("\nSinais (L = 1.645):\n")
